generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  createdAt DateTime  @default(now())
  firstName String?
  lastName  String?
  username  String    @unique
  accounts  Account[]
  posts     Post[]
  replies   Reply[]

  @@index([email])
  @@index([username])
}

model Account {
  id                String    @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  passwordHash      String?
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  replies   Reply[]

  @@index([createdAt])
  @@index([userId])
}

model Reply {
  id            String   @id @default(uuid())
  postId        String
  userId        String
  parentReplyId String?
  content       String
  createdAt     DateTime @default(now())
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Reply?   @relation("ReplyToReply", fields: [parentReplyId], references: [id], onDelete: Cascade)
  children      Reply[]  @relation("ReplyToReply")

  @@index([postId])
  @@index([userId])
  @@index([parentReplyId])
  @@index([createdAt])
}
