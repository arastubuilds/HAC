generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  createdAt DateTime  @default(now())
  firstName String?
  lastName  String?
  username  String    @unique
  accounts  Account[]
  posts     Post[]
  replies   Reply[]

  @@index([email])
  @@index([username])
}

model Account {
  id                String    @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  passwordHash      String?
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model Post {
  id               String   @id @default(uuid())
  title            String
  content          String
  createdAt        DateTime @default(now())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  replies          Reply[]
  originPlatform   String?
  waMessageKey     String?  @unique
  waThreadKey      String?
  importRunId      String?
  relevanceScore   Float?
  threadConfidence Float?
  medicalRisk      String?

  @@index([createdAt])
  @@index([userId])
  @@index([originPlatform])
  @@index([waThreadKey])
}

model Reply {
  id               String   @id @default(uuid())
  postId           String
  userId           String
  parentReplyId    String?
  content          String
  createdAt        DateTime @default(now())
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           Reply?   @relation("ReplyToReply", fields: [parentReplyId], references: [id], onDelete: Cascade)
  children         Reply[]  @relation("ReplyToReply")
  originPlatform   String?
  waMessageKey     String?  @unique
  waThreadKey      String?
  importRunId      String?
  relevanceScore   Float?
  threadConfidence Float?
  medicalRisk      String?

  @@index([postId])
  @@index([userId])
  @@index([parentReplyId])
  @@index([createdAt])
  @@index([originPlatform])
  @@index([waThreadKey])
}

model ImportRun {
  id                String           @id @default(uuid())
  sourceFile        String
  status            String
  startedAt         DateTime         @default(now())
  completedAt       DateTime?
  totalLines        Int              @default(0)
  parsedMessages    Int              @default(0)
  droppedMessages   Int              @default(0)
  parseFailures     Int              @default(0)
  createdPosts      Int              @default(0)
  createdReplies    Int              @default(0)
  skippedDuplicates Int              @default(0)
  qaReviewThreads   Int              @default(0)
  parserVersion     String?
  classifierVersion String?
  threadingVersion  String?
  embeddingModel    String?
  llmModel          String?
  configVersion     String?
  publishVersion    String?
  importMode        String?
  llmFailures       Int              @default(0)
  embedFailures     Int              @default(0)
  dbWriteFailures   Int              @default(0)
  messageStagings   MessageStaging[]
}

model MessageStaging {
  id                    String       @id @default(uuid())
  waMessageKey          String
  importRunId           String
  importRun             ImportRun    @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  timestamp             DateTime
  senderPseudonym       String
  rawBody               String
  normalizedBody        String
  isSystem              Boolean      @default(false)
  isMedia               Boolean      @default(false)
  language              Language
  parseConfidence       Float        @default(1.0)
  wasDropped            Boolean      @default(false)
  dropReason            DropReason?
  medicalRelevanceScore Float?
  anchorLikelihoodScore Float?
  replyLikelihoodScore  Float?
  categoryHits          Int?
  contentType           ContentType?

  @@unique([waMessageKey, importRunId])
  @@index([importRunId])
}

enum Language {
  english
  hinglish
}

enum DropReason {
  system_message
  media_only
  no_alphanumeric
  too_short
  spam_sender
  spam_content
  bare_url
  meeting_link
  social_link_no_med
}

enum ContentType {
  question
  experience
  recommendation
  ack
  logistics
  noise
}
