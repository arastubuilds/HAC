{
  "name": "hac-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev":        "pnpm --filter server dev",
    "dev:web":    "pnpm --filter web dev",
    "dev:api":    "pnpm --filter server dev:api",
    "dev:worker": "pnpm --filter server dev:worker",
    "build":      "pnpm -r build",
    "lint":       "pnpm -r lint",
    "format":     "pnpm -r format"
  }
}
